{
  "name": "zenithpay-api",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "bunx --env-file=.env drizzle-kit generate --config=drizzle.config.ts",
    "db:push": "bunx --env-file=.env drizzle-kit push --config=drizzle.config.ts",
    "db:migrate": "bunx --env-file=.env drizzle-kit migrate --config=drizzle.config.ts",
    "db:studio": "bunx --env-file=.env drizzle-kit studio --config=drizzle.config.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.99.1",
    "@x402/fetch": "^2.6.0",
    "@x402/hono": "^2.6.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.7",
    "hono-rate-limiter": "^0.5.3",
    "hpke-js": "^1.8.0",
    "postgres": "^3.4.8",
    "viem": "^2.47.2",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.9.3"
  }
}
